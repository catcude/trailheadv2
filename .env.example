# Copy to .env.local and fill in — see docs/SETUP.md for provisioning steps.
# Without Supabase keys the app still runs: public pages work, auth pages
# show a "not configured" note, and protected pages redirect to sign-in.

# --- Supabase (required for profiles + login) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM (lib/llm/provider.ts) ---
# "verbatim" runs the whole product on authored content only — no key needed.
LLM_PROVIDER=verbatim
LLM_API_KEY=
LLM_MODEL=

# --- Stripe (needed at Milestone 2, not for local auth) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=

# --- Feature flags (lib/flags.ts) — leave false/unset locally ---
NEXT_PUBLIC_FF_BLUE_PATH=false
# FF_RED_PATH / RED_PATH_RELEASE_APPROVED: never set in any committed env file,
# CI config, or Vercel environment — see docs/safety/red-path-review.md.
FF_DASHBOARD_EXTRAS=false
FF_QUIZ_SCORING=false
SAFETY_CLASSIFIER=false
